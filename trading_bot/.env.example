# ==============================================================================
# Binance Futures Simplified Trading Bot - Configuration Template
# ==============================================================================

# Your Binance Futures API credentials.
# Get these from the Futures Testnet API key section on Binance.
# Never commit your actual keys to public version control!
API_KEY=your_binance_testnet_api_key_here
API_SECRET=your_binance_testnet_api_secret_here

# Base URL for REST endpoint requests. Default is Futures Testnet.
BASE_URL=https://testnet.binancefuture.com

# Request settings
TIMEOUT=10
MAX_RETRIES=3
RETRY_BACKOFF_FACTOR=1.5
